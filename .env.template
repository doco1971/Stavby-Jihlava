# =============================================================
# Stavby App — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to Git — it contains secret keys!
# .env is already in .gitignore.
#
# Each company instance has its own .env with different values.
# The application code (App.jsx) is identical across all instances.
# =============================================================

# ── SUPABASE — PRODUCTION ─────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

VITE_SB_URL=https://REPLACE_WITH_YOUR_PROJECT.supabase.co
VITE_SB_KEY=REPLACE_WITH_YOUR_ANON_KEY

# ── SUPABASE — STAGING (optional) ────────────────────────────
# Separate Supabase project used for testing new features.
# Only needed if you set up a staging branch in Cloudflare Pages / Vercel.
# Leave empty if you don't have a staging environment yet.

VITE_SB_URL_STAGING=
VITE_SB_KEY_STAGING=

# =============================================================
# WHERE EACH VALUE COMES FROM
# =============================================================
#
# VITE_SB_URL:
#   Supabase Dashboard → your project → Settings → API
#   → "Project URL"  (looks like: https://abcdefgh.supabase.co)
#
# VITE_SB_KEY:
#   Supabase Dashboard → your project → Settings → API
#   → "Project API keys" → anon / public
#   (NOT the service_role key — that one stays on the server only)
#
# =============================================================
# SUPABASE EDGE FUNCTION SECRETS (set separately in Supabase)
# =============================================================
# These are NOT in .env — they are set directly in Supabase:
#   Supabase Dashboard → Edge Functions → Manage secrets
#
#   RESEND_API_KEY          — API key from resend.com (for email notifications)
#   FROM_EMAIL              — e.g. stavby_firma@yourdomain.cz
#   SUPABASE_URL            — automatically available in Edge Functions
#   SUPABASE_SERVICE_ROLE_KEY — automatically available in Edge Functions
#
# =============================================================
